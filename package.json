{
  "name": "haven-va",
  "version": "0.1.0",
  "private": true,
  "description": "Haven VA — Telegram-Notion-Claude bot for The Haven founders, NAS deployment",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"import('fs').then(fs=>{fs.readdirSync('src/prompts').filter(f=>f.endsWith('.md')).forEach(f=>{fs.mkdirSync('dist/prompts',{recursive:true});fs.copyFileSync('src/prompts/'+f,'dist/prompts/'+f)})})\"",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "dev": "node --watch dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@notionhq/client": "^2.2.15",
    "googleapis": "^140.0.0",
    "grammy": "^1.31.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
